# ─── Upstash Redis (KV store for RSVPs + guest codes) ────────────────────────
# Obtain from: https://console.upstash.com → your Redis database → REST API tab
# Or via Vercel: Settings → Integrations → Upstash → Connect, then Vercel
# automatically injects these as env vars.
KV_REST_API_URL=https://YOUR-DATABASE.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token

# ─── Resend (transactional email for RSVP confirmations) ─────────────────────
# Obtain from: https://resend.com → API Keys → Create API Key
# Requires a verified sending domain in Resend.
RESEND_API_KEY=re_your_resend_api_key

# ─── Seed secret (guards the /api/seed endpoint) ─────────────────────────────
# A random string you generate — only used when seeding initial guest data.
# Generate with: openssl rand -hex 24
# Must match SEED_SECRET when running: node seed-data.js
SEED_SECRET=your-random-seed-secret

# ─── Admin authentication ──────────────────────────────────────────────────────
# ADMIN_PASSWORD (required for admin access)
# The password you enter on the admin login screen.
# Generate a strong one with: openssl rand -base64 18
ADMIN_PASSWORD=your-strong-admin-password

# ADMIN_SESSION_SECRET (optional — set this in production for full control)
# Random 32+ byte string used to sign admin session tokens.
# If unset, a stable secret is derived from ADMIN_PASSWORD via SHA-256.
# ⚠  Rotating ADMIN_PASSWORD when ADMIN_SESSION_SECRET is NOT set will
#    invalidate all existing admin sessions (everyone is logged out).
#    Set ADMIN_SESSION_SECRET independently to decouple password rotation
#    from session invalidation.
# Generate with: openssl rand -base64 32
# ADMIN_SESSION_SECRET=your-random-session-secret
