# ─── Upstash Redis (KV store for RSVPs + guest codes) ────────────────────────
# Obtain from: https://console.upstash.com → your Redis database → REST API tab
# Or via Vercel: Settings → Integrations → Upstash → Connect, then Vercel
# automatically injects these as env vars.
KV_REST_API_URL=https://YOUR-DATABASE.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token

# ─── Resend (transactional email for RSVP confirmations) ─────────────────────
# Obtain from: https://resend.com → API Keys → Create API Key
# Requires a verified sending domain in Resend.
RESEND_API_KEY=re_your_resend_api_key

# ─── Seed secret (guards the /api/seed endpoint) ─────────────────────────────
# A random string you generate — only used when seeding initial guest data.
# Generate with: openssl rand -hex 24
# Must match SEED_SECRET when running: node seed-data.js
SEED_SECRET=your-random-seed-secret
